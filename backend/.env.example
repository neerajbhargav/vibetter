# AI Provider: gemini | openai | anthropic | ollama
# Auto-detected from API key if unset.
# VIBETTER_PROVIDER=gemini

# API Keys (only set the one for your chosen provider)
# Gemini:    https://aistudio.google.com/apikey
# GEMINI_API_KEY=your_key_here
# OpenAI:    https://platform.openai.com/api-keys
# OPENAI_API_KEY=your_key_here
# Anthropic: https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=your_key_here

# Ollama (local models, no API key needed)
# OLLAMA_BASE_URL=http://localhost:11434

# Override the default model for your provider
# VIBETTER_MODEL=gpt-4o

# Absolute path to the codebase you want VIBETTER to analyze.
# Leave unset to default to the working directory at server startup.
# VIBETTER_CODEBASE_PATH=/path/to/your/project
